{
  "name": "luxtorque",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "db:smoke": "bash scripts/db-smoke-test.sh",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:seed": "pnpm --filter @luxtorque/api exec prisma db seed",
    "db:migrate": "pnpm --filter @luxtorque/api exec prisma migrate dev",
    "db:reset": "pnpm --filter @luxtorque/api exec prisma migrate reset --force"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.8.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "devDependencies": {
    "tsx": "^4.23.0"
  }
}
